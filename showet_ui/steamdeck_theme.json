{
  "name": "steamdeck-dark",
  "description": "Optimized Steam Deck controller interface for Showet",
  "colors": {
    "primary": "#ff6b00",
    "secondary": "#ff2d55",
    "accent": "#00d4ff",
    "background": "#0a0a0a",
    "panel": "#1a1a1a",
    "text": "#e0e0e0",
    "success": "#00ff88",
    "warning": "#ffaa00",
    "danger": "#ff4444"
  },
  "layout": {
    "button_size": "large",
    "touch_targets": 60,
    "font_scale": 1.3
  },
  "controller_mapping": {
    "a": {
      "key": "a",
      "label": "Select/Run",
      "color": "primary"
    },
    "b": {
      "key": "b", 
      "label": "Back",
      "color": "warning"
    },
    "x": {
      "key": "x",
      "label": "Menu/Filter",
      "color": "secondary"
    },
    "y": {
      "key": "y",
      "label": "Shader Toggle",
      "color": "accent"
    },
    "start": {
      "key": "start",
      "label": "Play/Pause",
      "color": "success"
    },
    "select": {
      "key": "select",
      "label": "Settings",
      "color": "panel"
    },
    "l": {
      "key": "l",
      "label": "Seek <<",
      "color": "primary"
    },
    "r": {
      "key": "r",
      "label": "Seek >>",
      "color": "primary"
    },
    "left_stick": {
      "key": "left_stick",
      "label": "Navigate Menu",
      "axis": true
    },
    "right_stick": {
      "key": "right_stick",
      "label": "Quick Demo Switch",
      "axis": true
    }
  }
}